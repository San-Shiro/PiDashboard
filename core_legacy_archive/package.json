{
  "name": "pi-dashboard-workspace",
  "private": true,
  "workspaces": [
    "admin",
    "server",
    "mobile"
  ],
  "scripts": {
    "dev:server": "bun --hot server/index.ts",
    "dev:admin": "npm run dev --workspace=admin",
    "dev:mobile": "npx expo start --cwd mobile",
    "build:admin": "npm run build --workspace=admin",
    "install:all": "npm install && bun install --cwd server"
  }
}
