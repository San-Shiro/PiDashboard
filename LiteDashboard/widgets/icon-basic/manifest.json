{
  "id": "icon-basic",
  "name": "Vector Icon",
  "version": "1.0.0",
  "author": "PiDashboard",
  "description": "A scalable vector icon from a curated set of standard icons.",
  "category": "Design",
  "icon": "star",
  "tier": "static",
  "estimatedRamMb": 1,
  "trust": "verified",
  "permissions": {
    "network": false,
    "disk": false
  },
  "fragment": {
    "file": "icon-basic.html",
    "format": "snippet"
  },
  "configSchema": [
    {
      "key": "iconName",
      "type": "radio",
      "label": "Icon",
      "options": [
        "home",
        "star",
        "heart",
        "settings",
        "info",
        "check",
        "warning",
        "user",
        "clock",
        "music"
      ],
      "default": "star"
    },
    {
      "key": "iconColor",
      "type": "color",
      "label": "Icon Color",
      "default": "#ffffff"
    },
    {
      "key": "iconSize",
      "type": "slider",
      "label": "Icon Size",
      "min": 10,
      "max": 200,
      "step": 1,
      "unit": "px",
      "default": 48
    },
    {
      "key": "strokeWidth",
      "type": "slider",
      "label": "Stroke Thickness",
      "min": 1,
      "max": 5,
      "step": 0.5,
      "unit": "px",
      "default": 2
    }
  ],
  "stateMode": "instance",
  "persist": false,
  "defaults": {
    "width": 64,
    "height": 64
  },
  "dataChannel": {
    "type": "none"
  }
}