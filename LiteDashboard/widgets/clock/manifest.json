{
  "id": "clock",
  "name": "Digital Clock",
  "version": "1.1.0",
  "author": "PiDashboard",
  "description": "A premium digital clock with configurable format, timezone, and styling",
  "runtimeTier": "lite",
  "trust": "verified",
  "permissions": {
    "network": false,
    "disk": false
  },
  "resources": {
    "externalFonts": [
      "Inter",
      "Outfit",
      "Plus Jakarta Sans",
      "Poppins",
      "Montserrat",
      "Manrope",
      "DM Sans",
      "Space Grotesk",
      "Roboto",
      "Merriweather",
      "Playfair Display",
      "Bebas Neue",
      "Noto Sans",
      "Noto Sans Devanagari",
      "Noto Serif Devanagari",
      "Mukta",
      "Hind",
      "Anek Devanagari"
    ]
  },
  "fragment": {
    "file": "clock.html",
    "format": "snippet"
  },
  "configSchema": [
    {
      "key": "showSeconds",
      "type": "boolean",
      "label": "Show Seconds",
      "default": true,
      "panel": "performance",
      "hint": "Turning seconds off lowers update intensity on lighter devices.",
      "hintDisplay": "icon"
    },
    {
      "key": "use24h",
      "type": "boolean",
      "label": "24-Hour Format",
      "default": false
    },
    {
      "key": "showDate",
      "type": "boolean",
      "label": "Show Date",
      "default": false
    },
    {
      "key": "timezone",
      "type": "timezone",
      "label": "Timezone",
      "hint": "Leave blank for system default",
      "default": ""
    },
    {
      "key": "fontFamily",
      "type": "select",
      "label": "Font Family",
      "options": [
        "Inter, system-ui, sans-serif",
        "Outfit, system-ui, sans-serif",
        "\"Plus Jakarta Sans\", system-ui, sans-serif",
        "Poppins, system-ui, sans-serif",
        "Montserrat, system-ui, sans-serif",
        "Manrope, system-ui, sans-serif",
        "\"DM Sans\", system-ui, sans-serif",
        "\"Space Grotesk\", system-ui, sans-serif",
        "\"Segoe UI\", system-ui, sans-serif",
        "Roboto, Arial, sans-serif",
        "\"Noto Sans\", system-ui, sans-serif",
        "\"Noto Sans Devanagari\", system-ui, sans-serif",
        "\"Noto Serif Devanagari\", Georgia, serif",
        "Mukta, system-ui, sans-serif",
        "Hind, system-ui, sans-serif",
        "\"Anek Devanagari\", system-ui, sans-serif",
        "\"Bebas Neue\", system-ui, sans-serif",
        "\"Merriweather\", Georgia, serif",
        "\"Playfair Display\", Georgia, serif",
        "system-ui, sans-serif"
      ],
      "default": "Inter, system-ui, sans-serif"
    },
    {
      "key": "fontWeight",
      "type": "select",
      "label": "Font Weight",
      "options": [
        "200",
        "300",
        "400",
        "500",
        "600",
        "700",
        "800"
      ],
      "default": "300"
    },
    {
      "key": "fontSize",
      "type": "slider",
      "label": "Font Size",
      "min": 16,
      "max": 120,
      "step": 2,
      "unit": "px",
      "default": 48
    },
    {
      "key": "textColor",
      "type": "color",
      "label": "Text Color",
      "hint": "Leave blank to use canvas theme",
      "default": ""
    },
    {
      "key": "glowColor",
      "type": "color",
      "label": "Glow Line",
      "default": ""
    },
    {
      "key": "separatorBlink",
      "type": "boolean",
      "label": "Blinking Separator",
      "default": true,
      "panel": "performance",
      "hint": "Disabling the blink keeps the clock a little calmer and lighter.",
      "hintDisplay": "icon"
    }
  ],
  "stateMode": "instance",
  "persist": false,
  "category": "Time",
  "icon": "clock",
  "tier": "static",
  "estimatedRamMb": 1,
  "defaults": {
    "width": 300,
    "height": 120
  },
  "dataChannel": {
    "type": "none"
  }
}
