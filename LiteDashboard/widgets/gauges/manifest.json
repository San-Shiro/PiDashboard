{
  "id": "gauges",
  "name": "System Gauges",
  "version": "1.0.0",
  "author": "PiDashboard",
  "description": "Circular SVG ring gauges for CPU, RAM, and temperature monitoring",
  "category": "System",
  "icon": "gauge",
  "tier": "static",
  "trust": "verified",
  "estimatedRamMb": 2,
  "permissions": {
    "network": false,
    "disk": false
  },
  "fragment": {
    "file": "gauges.html",
    "format": "snippet"
  },
  "daemon": "sysinfo",
  "configSchema": [
    {
      "key": "showTemp",
      "type": "boolean",
      "default": true,
      "label": "Show Temperature"
    },
    {
      "key": "showDisk",
      "type": "boolean",
      "default": false,
      "label": "Show Disk (replaces Temp)"
    },
    {
      "key": "animationSpeed",
      "type": "number",
      "default": 0.8,
      "min": 0.3,
      "max": 2,
      "step": 0.1,
      "unit": "s",
      "label": "Animation Speed"
    }
  ],
  "stateMode": "global",
  "persist": false,
  "defaults": {
    "width": 450,
    "height": 180
  },
  "dataChannel": {
    "type": "none"
  }
}