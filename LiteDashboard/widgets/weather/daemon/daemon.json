{
  "id": "weather",
  "name": "Live Weather Fetcher",
  "version": "1.0.0",

  "runtime": {
    "command": "./weather.sh",
    "shell": true,
    "cwd": "daemon"
  },

  "communication": {
    "mode": "ipc_file",
    "ipcFilename": "weather.json"
  },

  "health": {
    "strategy": "file_mtime",
    "maxStaleSec": 900,
    "startupGraceSec": 10
  },

  "restart": {
    "policy": "on-failure",
    "maxRestarts": 5,
    "backoffBaseSec": 5,
    "backoffMaxSec": 300
  },

  "resources": {
    "maxMemoryMB": 10
  },

  "dependencies": {
    "system": ["bash", "curl", "jq"]
  }
}
