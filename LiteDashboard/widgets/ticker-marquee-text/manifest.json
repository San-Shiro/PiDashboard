{
  "id": "ticker-marquee-text",
  "name": "Ticker / Marquee Text",
  "version": "1.0.0",
  "author": "PiDashboard",
  "description": "Scrolling text strip for announcements, notices, and compact updates.",
  "category": "Typography",
  "icon": "panel-top",
  "tier": "static",
  "runtimeTier": "lite",
  "estimatedRamMb": 1,
  "trust": "verified",
  "permissions": {
    "network": false,
    "disk": false
  },
  "resources": {
    "externalFonts": [
      "Inter",
      "Outfit",
      "Plus Jakarta Sans",
      "Poppins",
      "Montserrat",
      "Manrope",
      "DM Sans",
      "Space Grotesk",
      "Roboto",
      "Bebas Neue",
      "Noto Sans",
      "Noto Sans Devanagari",
      "Noto Serif Devanagari",
      "Mukta",
      "Hind",
      "Anek Devanagari"
    ]
  },
  "fragment": {
    "file": "ticker-marquee-text.html",
    "format": "snippet"
  },
  "configSchema": [
    { "key": "items", "type": "textarea", "label": "Items", "rows": 6, "default": "Welcome to PiDashboard\nTeam standup at 10:30\nScreening room opens at 18:00" },
    { "key": "separator", "type": "text", "label": "Separator", "default": "•" },
    { "key": "direction", "type": "radio", "label": "Direction", "options": [{ "value": "left", "label": "Left" }, { "value": "right", "label": "Right" }], "default": "left" },
    { "key": "speed", "type": "slider", "label": "Speed", "min": 20, "max": 140, "step": 5, "unit": "u", "default": 70 },
    { "key": "gap", "type": "slider", "label": "Gap", "min": 20, "max": 120, "step": 4, "unit": "px", "default": 48 },
    { "key": "fontFamily", "type": "select", "label": "Font Family", "options": ["Inter, system-ui, sans-serif", "Outfit, system-ui, sans-serif", "\"Plus Jakarta Sans\", system-ui, sans-serif", "Poppins, system-ui, sans-serif", "Montserrat, system-ui, sans-serif", "Manrope, system-ui, sans-serif", "\"DM Sans\", system-ui, sans-serif", "\"Space Grotesk\", system-ui, sans-serif", "\"Bebas Neue\", system-ui, sans-serif", "Roboto, Arial, sans-serif", "\"Noto Sans\", system-ui, sans-serif", "\"Noto Sans Devanagari\", system-ui, sans-serif", "\"Noto Serif Devanagari\", Georgia, serif", "Mukta, system-ui, sans-serif", "Hind, system-ui, sans-serif", "\"Anek Devanagari\", system-ui, sans-serif", "system-ui, sans-serif"], "default": "Inter, system-ui, sans-serif" },
    { "key": "fontSize", "type": "slider", "label": "Size", "min": 12, "max": 48, "step": 1, "unit": "px", "default": 24 },
    { "key": "fontWeight", "type": "select", "label": "Weight", "options": ["400", "500", "600", "700", "800"], "default": "700" },
    { "key": "uppercase", "type": "boolean", "label": "Uppercase", "default": false },
    { "key": "fpsLimit", "type": "number", "label": "FPS Limit", "min": 5, "max": 60, "step": 1, "default": 30, "hint": "Lower FPS reduces motion work and can help lighter devices.", "hintDisplay": "icon", "panel": "performance" },
    { "key": "pauseOnHover", "type": "boolean", "label": "Pause on Hover", "default": false, "panel": "performance" },
    { "key": "textColor", "type": "color", "label": "Text Color", "default": "#ffffff" },
    { "key": "accentColor", "type": "color", "label": "Separator Color", "default": "#60a5fa" },
    { "key": "background", "type": "background", "label": "Background", "default": { "type": "classic", "color": "rgba(255,255,255,0.05)", "color2": "#111827", "stops": [{ "color": "rgba(255,255,255,0.05)", "position": 0 }, { "color": "rgba(99,102,241,0.12)", "position": 50 }, { "color": "#111827", "position": 100 }], "gradientType": "linear", "angle": 135, "mix": 50, "softness": 100 } }
  ],
  "stateMode": "instance",
  "persist": false,
  "defaults": {
    "width": 900,
    "height": 72
  },
  "dataChannel": {
    "type": "none"
  }
}
