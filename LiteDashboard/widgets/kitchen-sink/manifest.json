{
  "id": "kitchen-sink",
  "name": "Kitchen Sink Styles",
  "description": "A widget that includes every config field type for testing styling.",
  "version": "1.0.0",
  "author": "Antigravity",
  "defaultWidth": 300,
  "defaultHeight": 300,
  "configSchema": [
    {
      "key": "test_text",
      "type": "text",
      "label": "Text Field",
      "hint": "This is a simple text input.",
      "placeholder": "Enter something...",
      "default": "Hello World"
    },
    {
      "key": "test_number",
      "type": "number",
      "label": "Number Field",
      "hint": "This is a simple number input.",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 42
    },
    {
      "key": "test_slider",
      "type": "slider",
      "label": "Slider Field",
      "hint": "This is a slider.",
      "min": 0,
      "max": 100,
      "unit": "%",
      "default": 50
    },
    {
      "key": "test_toggle",
      "type": "toggle",
      "label": "Toggle Field",
      "hint": "This is a boolean switch.",
      "default": true
    },
    {
      "key": "test_color",
      "type": "color",
      "label": "Color Field",
      "hint": "This is a color picker.",
      "default": "#ff0055"
    },
    {
      "key": "test_time",
      "type": "time",
      "label": "Time Field",
      "hint": "This is a time selector.",
      "default": "12:00"
    },
    {
      "key": "test_timezone",
      "type": "timezone",
      "label": "Timezone Field",
      "hint": "This is a timezone dropdown.",
      "default": "UTC"
    },
    {
      "key": "test_select",
      "type": "select",
      "label": "Select Field",
      "hint": "This is a simple dropdown.",
      "options": [
        { "value": "opt1", "label": "Option 1" },
        { "value": "opt2", "label": "Option 2" },
        { "value": "opt3", "label": "Option 3" }
      ],
      "default": "opt1"
    },
    {
      "key": "test_radio",
      "type": "radio",
      "label": "Radio Field",
      "hint": "This is a set of radio cards.",
      "options": [
        { "value": "light", "label": "Light Theme" },
        { "value": "dark", "label": "Dark Theme" },
        { "value": "system", "label": "System Match" }
      ],
      "default": "dark"
    },
    {
      "key": "test_file",
      "type": "file",
      "label": "File Field",
      "hint": "This is a file or image picker.",
      "accepts": "image/*",
      "default": ""
    }
  ]
}
