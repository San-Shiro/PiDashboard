{
  "id": "weather",
  "name": "Live Weather",
  "version": "1.0.0",
  "tier": "1b",
  "entrypoints": {
    "fragment": "fragment/weather.html",
    "fetchModule": "fetch/weather.ts"
  },
  "configSchema": [
    {
      "key": "locationName",
      "type": "text",
      "default": "London, UK",
      "label": "Location Name (e.g., Paris, New York)"
    },
    {
      "key": "units",
      "type": "select",
      "options": [
        {"label": "Metric (°C, km/h)", "value": "metric"},
        {"label": "Imperial (°F, mph)", "value": "imperial"}
      ],
      "default": "metric",
      "label": "Temperature Unit"
    }
  ]
}
